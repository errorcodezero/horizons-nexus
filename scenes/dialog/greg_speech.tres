dialogs = {
"BERLIN_DIALOG_7": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"BERLIN_DIALOG_8": {
"default": "The concrete jungle of Berlin is loud, polluted, and ripe for a tactical drop. We're cutting off their industrial momentum right here. Aim for the crowded squares. No mercy.",
"en": ""
},
"BERLIN_DIALOG_9": {
"default": "Schau! Da zeichnet sich etwas am Horizont ab.",
"en": ""
},
"BOGOTA_DIALOG_19": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"BOGOTA_DIALOG_20": {
"default": "A high-altitude bonus mission for the bravest bird in the skies. Bogotá is nestled right in the Andes. It's perfect cover for a surprise drop. Let's paint the town white.",
"en": ""
},
"BOGOTA_DIALOG_21": {
"default": "¡Mira! Hay algo en el horizonte.",
"en": ""
},
"CAIRO_DIALOG_4": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"CAIRO_DIALOG_5": {
"default": "They think they can choke the Nile with plastic and dust? Not on my watch. Watch the desert wind currents on your approach, soldier. Target the historic Pyramids of Giza.",
"en": ""
},
"CAIRO_DIALOG_6": {
"default": "هناك شيء يلوح في الأفق",
"en": ""
},
"SF_DIALOG_1": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SF_DIALOG_2": {
"default": "Flock Fighter, look at that skyline. Smog, exhaust, Waymos, AI Ads... it’s a gray nightmare. You're diving straight through the fog for this one. Line up your crosshairs right over the [color=c0362d]Golden Gate Bridge[/color] and make it count.",
"en": ""
},
"SF_DIALOG_3": {
"default": "Hey, check it out... there's something on the horizon.",
"en": ""
},
"SINGAPORE_DIALOG_13": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SINGAPORE_DIALOG_14": {
"default": "Singapore is one of the greenest cities on earth, but they're still humans, and they still pollute. We need total destruction of Marina Bay and beyond. Do not fail me.",
"en": ""
},
"SINGAPORE_DIALOG_15": {
"default": "Singapore is one of the greenest cities on earth, but they're still humans, and they still pollute. We need total saturation over Marina Bay. Keep your feathers dry, because 'தொடுவானத்தில் ஏதோ ஒன்று தெரிகிறது' (Something is visible on the horizon). Do not fail me.",
"en": ""
},
"SYDNEY_DIALOG_10": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SYDNEY_DIALOG_11": {
"default": "We’re heading down under, wing-brother. Gravity feels a bit different when you're flying inverted, but your aim better stay true. Let's give the folks down by the Opera House something to look up at.",
"en": ""
},
"SYDNEY_DIALOG_12": {
"default": "˙uozıɹoɥ ǝɥʇ uo ƃuıɥʇǝɯos s,ǝɹǝɥʇ ¡ʞool",
"en": ""
},
"TORONTO_DIALOG_16": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"TORONTO_DIALOG_17": {
"default": "It’s freezing up north, soldier, so make sure your wings don't icing up. We're targeting the CN Tower. They're going to be apologizing to each other for weeks after we're done.",
"en": ""
},
"TORONTO_DIALOG_18": {
"default": "Look! There's something on the horizon, ay",
"en": ""
}
}
