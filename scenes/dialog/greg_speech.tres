dialogs = {
"BERLIN_DIALOG_7": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"BERLIN_DIALOG_8": {
"default": "The concrete jungle of Berlin is loud, polluted, and ripe for a tactical drop. We're cutting off their industrial momentum right here. Aim for the crowded squares. No mercy.",
"en": ""
},
"BERLIN_DIALOG_9": {
"default": "Schau! Da zeichnet sich etwas am Horizont ab.",
"en": ""
},
"CAIRO_DIALOG_4": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"CAIRO_DIALOG_5": {
"default": "They think they can choke the Nile with plastic and dust? Not on my watch. Watch the desert wind currents on your approach, soldier. Target the historic Pyramids of Giza.",
"en": ""
},
"CAIRO_DIALOG_6": {
"default": "هناك شيء يلوح في الأفق",
"en": ""
},
"SF_DIALOG_1": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SF_DIALOG_2": {
"default": "Flock Fighter, look at that skyline. Smog, exhaust, Waymos, AI Ads... it’s a gray nightmare. You're diving straight through the fog for this one. Line up your crosshairs right over the [color=c0362d]Golden Gate Bridge[/color] and make it count.",
"en": ""
},
"SF_DIALOG_3": {
"default": "Hey, check it out... there's something on the horizon.",
"en": ""
},
"SYDNEY_DIALOG_10": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SYDNEY_DIALOG_11": {
"default": "We’re heading down under, wing-brother. Gravity feels a bit different when you're flying inverted, but your aim better stay true. Let's give the folks down by the Opera House something to look up at.",
"en": ""
},
"SYDNEY_DIALOG_12": {
"default": "˙uozıɹoɥ ǝɥʇ uo ƃuıɥʇǝɯos s,ǝɹǝɥʇ ¡ʞool",
"en": ""
}
