"CAIRO_DIALOG_4": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"CAIRO_DIALOG_5": {
"default": "They think they can choke the Nile with plastic and dust? Not on my watch. Watch the desert wind currents on your approach, soldier. Target the historic Pyramids of Giza.",
"en": ""
},
"CAIRO_DIALOG_6": {
"default": "هناك شيء يلوح في الأفق",
"en": ""
},
"SF_DIALOG_1": {
"default": "[font s=40.0][wave]CALLING[/wave][/font][/color]",
"en": ""
},
"SF_DIALOG_2": {
"default": "Flock Fighter, look at that skyline. Smog, exhaust, Waymos, AI Ads... it’s a gray nightmare. You're diving straight through the fog for this one. Line up your crosshairs right over the [color=c0362d]Golden Gate Bridge[/color] and make it count.",
"en": ""
},
"SF_DIALOG_3": {
"default": "Hey, check it out... there's something on the horizon.",
"en": ""
}
}
